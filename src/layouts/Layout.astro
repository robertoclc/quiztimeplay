---
import "../styles/global.css";
import "../styles/header.css";
import "../styles/hero.css";
import "../styles/cards.css";
import "../styles/categorias.css";
import "../styles/footer.css";
import "../styles/search.css";
import "../styles/responsive.css";

interface Props {

    title?: string;

    description?: string;

}

const {

    title = "QuizTimePlay",

    description = "QuizTimePlay - O maior canal de quizzes do Brasil."

} = Astro.props;

const site = "https://quiztimeplay.com.br";

const image = `${site}/logo.png`;

const schema = {

    "@context": "https://schema.org",

    "@graph": [

        {

            "@type": "WebSite",

            "@id": `${site}/#website`,

            url: site,

            name: "QuizTimePlay",

            description,

            inLanguage: "pt-BR"

        },

        {

            "@type": "Organization",

            "@id": `${site}/#organization`,

            name: "QuizTimePlay",

            url: site,

            logo: {

                "@type": "ImageObject",

                url: image

            },

            sameAs: [

                "https://www.youtube.com/@QuizTime-Tc"

            ]

        }

    ]

};
---

<!DOCTYPE html>

<html lang="pt-BR">

<head>

<meta charset="UTF-8" />

<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>{title}</title>

<meta name="description" content={description} />

<meta name="author" content="QuizTimePlay" />

<meta name="robots" content="index,follow" />

<meta name="keywords" content="quiz, quizzes, conhecimentos gerais, futebol, história, ciência, música, cultura pop" />

<link rel="canonical" href={site} />

<meta name="theme-color" content="#2563eb" />

<meta property="og:type" content="website" />
<meta property="og:locale" content="pt_BR" />
<meta property="og:site_name" content="QuizTimePlay" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={site} />
<meta property="og:image" content={image} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />

<link rel="icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/logo.png" />

<link rel="preconnect" href="https://www.youtube.com">
<link rel="preconnect" href="https://i.ytimg.com">
<link rel="preconnect" href="https://www.googleapis.com">

<script
type="application/ld+json"
set:html={JSON.stringify(schema)}
></script>

<slot name="head" />

</head>

<body>

<slot />

</body>

</html>